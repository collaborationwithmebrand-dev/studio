
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /admin_roles/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == adminUid;
      allow update, delete: if isAdmin();
    }
    
    match /storeSettings/mainSettings {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /storeSettings/announcement {
      allow get: if true;
      allow write: if isAdmin();
    }
    
    match /publicDisplaySettings/theme {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /userProfiles/{userId} {
      allow get, write: if isOwner(userId);
      allow list: if isAdmin();
    }
    
    match /orders/{orderId} {
      // Create is allowed for any logged-in user
      allow create: if isSignedIn();
      
      // Get is allowed if you are the owner or the admin
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      // Administrators can list all orders
      // Regular users can only list their own orders
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.query.limit <= 50 && request.query.filters.size() > 0 && request.query.filters[0].field == 'userId' && request.query.filters[0].value == request.auth.uid)
      );
      
      // Update is for admins, or owners cancelling their own pending order
      allow update: if isAdmin() 
                   || (isOwner(resource.data.userId) && resource.data.status == 'pending' && request.resource.data.status == 'cancelled');
      
      // Delete is for admins, or owners deleting finished orders
      allow delete: if isAdmin()
                   || (isOwner(resource.data.userId) && (resource.data.status == 'delivered' || resource.data.status == 'cancelled'));
    }
  }
}
