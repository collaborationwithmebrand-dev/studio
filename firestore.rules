
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /admin_roles/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == adminUid;
      allow update, delete: if isAdmin() && request.auth.uid == adminUid;
    }
    match /storeSettings/mainSettings {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }
    match /publicDisplaySettings/theme {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /userProfiles/{userId} {
      allow get, write: if isOwner(userId);
      allow list: if isAdmin();
    }
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Explicitly separate admin and user list rules to prevent query rejection
      // Allow admins to see everything
      allow list: if isAdmin();
      // Allow users to see only their own orders with a safety limit
      allow list: if isSignedIn() && request.query.limit <= 20 && resource.data.userId == request.auth.uid;
      
      // Allow users to update status to 'cancelled' only if it's currently 'pending'
      allow update: if isAdmin() 
                   || (isOwner(resource.data.userId) && resource.data.status == 'pending' && request.resource.data.status == 'cancelled');
      
      // Allow users to delete their own orders if they are finished (delivered or cancelled)
      allow delete: if isAdmin()
                   || (isOwner(resource.data.userId) && (resource.data.status == 'delivered' || resource.data.status == 'cancelled'));
    }
  }
}
