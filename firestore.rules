rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // Products are public for reading
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders are private to the owner, but admins see all
    match /orders/{orderId} {
      // Split read into get and list for clarity and admin collection queries
      allow get: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if request.auth != null && (request.query.limit <= 50 && (isAdmin() || request.auth.uid != null));
      allow create: if request.auth != null;
      // Only admins can update order status (e.g., confirm, deliver, cancel)
      allow update, delete: if isAdmin();
    }

    // Store settings (Helpline, WhatsApp, Announcement) are public for customers
    match /storeSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public display settings (Theme) are public
    match /publicDisplaySettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User profiles
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin roles marker - Allow any authenticated user to claim their own admin status with the code
    match /admin_roles/{adminId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == adminId;
    }
  }
}