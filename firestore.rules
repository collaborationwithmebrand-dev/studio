
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /admin_roles/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == adminUid;
      allow update, delete: if isAdmin();
    }
    
    match /storeSettings/mainSettings {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /storeSettings/announcement {
      allow get: if true;
      allow write: if isAdmin();
    }
    
    match /publicDisplaySettings/theme {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /userProfiles/{userId} {
      allow get, write: if isOwner(userId);
      allow list: if isAdmin();
    }
    
    match /orders/{orderId} {
      allow create: if isSignedIn();
      // Allow read if the user is an admin or the owner of the order.
      // For listing, Firestore will check each document's userId against request.auth.uid.
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource == null) // Allow querying with where filters
      );
      allow update: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'pending');
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && (resource.data.status == 'delivered' || resource.data.status == 'cancelled'));
    }
  }
}
