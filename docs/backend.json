
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an item available for sale in the Bounsi Bazaar store.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string", "enum": ["gm", "Liter", "kg", "Pcs"] },
        "section": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "isCodAvailable": { "type": "boolean" },
        "isUpiAvailable": { "type": "boolean" },
        "isPinned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "unit", "section", "imageUrl", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "StoreSetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StoreSetting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "activeThemeName": { "type": "string" },
        "upiId": { "type": "string" },
        "upiQrUrl": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "helpLineNumber": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "Announcement": {
      "title": "Store Announcement",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "active": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "admin_role": {
      "title": "Admin Role",
      "type": "object",
      "properties": {
        "assignedAt": { "type": "string", "format": "date-time" }
      }
    },
    "public_theme_setting": {
      "title": "Public Theme Setting",
      "type": "object",
      "properties": {
        "activeThemeName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Public product catalog."
    },
    "/admin_roles/{adminUid}": {
      "schema": { "$ref": "#/backend/entities/admin_role" },
      "description": "Markers for users with admin access."
    },
    "/storeSettings/mainSettings": {
      "schema": { "$ref": "#/backend/entities/StoreSetting" },
      "description": "Sensitive administrative settings."
    },
    "/storeSettings/announcement": {
      "schema": { "$ref": "#/backend/entities/Announcement" },
      "description": "Global store announcement for all customers."
    },
    "/publicDisplaySettings/theme": {
      "schema": { "$ref": "#/backend/entities/public_theme_setting" },
      "description": "Publicly visible UI configuration."
    },
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User specific data like phone number."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Tracked customer orders."
    }
  }
}
