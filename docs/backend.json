
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an item available for sale in the Bounsi Bazaar store.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "unit": {
          "type": "string",
          "description": "The measurement unit (e.g., gm, Liter, kg, Pcs).",
          "enum": ["gm", "Liter", "kg", "Pcs"]
        },
        "section": {
          "type": "string",
          "description": "The custom section name for grouping products."
        },
        "category": {
          "type": "string",
          "description": "The broad category the product belongs to."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the product's image.",
          "format": "uri"
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "isCodAvailable": {
          "type": "boolean",
          "description": "Whether Cash on Delivery is available for this product."
        },
        "isUpiAvailable": {
          "type": "boolean",
          "description": "Whether UPI payment is available for this product."
        },
        "isPinned": {
          "type": "boolean",
          "description": "Whether the product is pinned to the top of the list."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the product was first added.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the product was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "unit",
        "section",
        "imageUrl",
        "createdAt"
      ]
    },
    "StoreSetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StoreSetting",
      "type": "object",
      "description": "Stores global configuration and aggregated statistics.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "totalOrders": {
          "type": "number"
        },
        "totalEarnings": {
          "type": "number"
        },
        "activeThemeName": {
          "type": "string"
        },
        "upiId": {
          "type": "string",
          "description": "The merchant UPI ID for payments."
        },
        "upiQrUrl": {
          "type": "string",
          "description": "The URL of the UPI QR code image.",
          "format": "uri"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "totalOrders",
        "totalEarnings",
        "activeThemeName",
        "lastUpdated"
      ]
    },
    "admin_role": {
      "title": "Admin Role",
      "type": "object",
      "properties": {
        "assignedAt": { "type": "string", "format": "date-time" }
      }
    },
    "public_theme_setting": {
      "title": "Public Theme Setting",
      "type": "object",
      "properties": {
        "activeThemeName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Public product catalog."
    },
    "/admin_roles/{adminUid}": {
      "schema": { "$ref": "#/backend/entities/admin_role" },
      "description": "Markers for users with admin access."
    },
    "/storeSettings/mainSettings": {
      "schema": { "$ref": "#/backend/entities/StoreSetting" },
      "description": "Sensitive administrative settings."
    },
    "/publicDisplaySettings/theme": {
      "schema": { "$ref": "#/backend/entities/public_theme_setting" },
      "description": "Publicly visible UI configuration."
    }
  }
}
