
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an item available for sale in the Bounsi Bazaar store.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "category": {
          "type": "string",
          "description": "The category the product belongs to (e.g., Food, Electronic, Fashion)."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the product's image.",
          "format": "uri"
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product, potentially generated by an AI tool."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the product was first added to the store.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the product's information was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "category",
        "imageUrl",
        "description",
        "createdAt"
      ]
    },
    "StoreSetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StoreSetting",
      "type": "object",
      "description": "Stores global configuration and aggregated statistics for the Bounsi Bazaar application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the StoreSetting entity."
        },
        "totalOrders": {
          "type": "number",
          "description": "The cumulative count of all orders recorded across the store."
        },
        "totalEarnings": {
          "type": "number",
          "description": "The cumulative revenue generated from all recorded orders."
        },
        "activeThemeName": {
          "type": "string",
          "description": "The name of the currently active festival theme."
        },
        "lastUpdated": {
          "type": "string",
          "description": "Timestamp of the last update.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "totalOrders",
        "totalEarnings",
        "activeThemeName",
        "lastUpdated"
      ]
    },
    "admin_role": {
      "title": "Admin Role",
      "type": "object",
      "properties": {
        "assignedAt": { "type": "string", "format": "date-time" }
      }
    },
    "public_theme_setting": {
      "title": "Public Theme Setting",
      "type": "object",
      "properties": {
        "activeThemeName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Public product catalog."
    },
    "/admin_roles/{adminUid}": {
      "schema": { "$ref": "#/backend/entities/admin_role" },
      "description": "Markers for users with admin access."
    },
    "/storeSettings/mainSettings": {
      "schema": { "$ref": "#/backend/entities/StoreSetting" },
      "description": "Sensitive administrative settings."
    },
    "/publicDisplaySettings/theme": {
      "schema": { "$ref": "#/backend/entities/public_theme_setting" },
      "description": "Publicly visible UI configuration."
    }
  }
}
